<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SquadApplication.ViewCustom.ProfilePage"
             BackgroundImageSource="mainprofile.jpg"
             Title="ProfilePage">
    <AbsoluteLayout>
        <BoxView AbsoluteLayout.LayoutFlags="All"
                 AbsoluteLayout.LayoutBounds="0,0,1,1">
            <BoxView.Background>
                <Color>#50809080</Color>
            </BoxView.Background>
        </BoxView>

        <!-- Тактическая сетка (очень прозрачная) -->
        

        <ScrollView AbsoluteLayout.LayoutFlags="All"
                    AbsoluteLayout.LayoutBounds="0,0,1,1"
                    VerticalScrollBarVisibility="Never">

            <VerticalStackLayout Spacing="15" Padding="20,20,20,40">

                <!-- Заголовок ПРОФИЛЬ -->
                <Border x:Name="TitleBorder"
                        Stroke="Transparent"
                        BackgroundColor="#50808080"
                        StrokeThickness="1"
                        StrokeShape="10"
                        Padding="15"
                        Opacity="0.8">
                    <Border.Shadow>
                        <Shadow Brush="#b3c96b" 
                                Offset="0,5" 
                                Opacity="0.5"
                                Radius="10"/>
                    </Border.Shadow>

                    <Label Text="ПРОФИЛЬ БОЙЦА"
                           TextColor="White"
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center"/>
                </Border>

                <!-- БЛОК 1: ОСНОВНАЯ ИНФОРМАЦИЯ -->
                <Border BackgroundColor="#50808080"
                        Stroke="#b3c96b"
                        StrokeThickness="1"
                        StrokeShape="15"
                        Padding="0"
                        Opacity="0.8">
                    <Border.Shadow>
                        <Shadow Brush="#b3c96b" 
                                Offset="0,0" 
                                Opacity="0.15"
                                Radius="15"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="0">
                        <!-- Заголовок блока -->
                        <Border BackgroundColor="#40808080"
                                Stroke="Transparent"
                                StrokeShape="0"
                                Padding="15,12">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="⚡"
                                       FontSize="20"
                                       TextColor="#b3c96b"/>
                                <Label Text="ОСНОВНЫЕ ДАННЫЕ"
                                       TextColor="White"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       VerticalTextAlignment="Center"/>
                                <Label Text="[01]"
                                       TextColor="#b3c96b"
                                       FontSize="12"
                                       Opacity="0.8"
                                       HorizontalOptions="Fill"
                                       VerticalTextAlignment="Center"/>
                                
                                <Border 
                                    Background="#90807010"
                                    Stroke="Yellow"
                                    StrokeShape="13">
                                       <Button 
                                          BackgroundColor="Transparent"
                                           Command="{Binding EditInfoUserCommand}"
                                           Text="{Binding EditData}"
                                          />
                                </Border>
                            </HorizontalStackLayout>
                        </Border>

                        <BoxView HeightRequest="1" 
                                 Color="#b3c96b" 
                                 Opacity="0.3"/>

                        <!-- Позывной крупно -->
                        <Border BackgroundColor="#30808080"
                                Padding="20,15"
                                Stroke="Transparent">
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <Label Grid.Column="0"
                                       Text="👤"
                                       FontSize="28"
                                       TextColor="#b3c96b"
                                       Margin="0,0,15,0"/>

                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="ПОЗЫВНОЙ"
                                           TextColor="#b3c96b"
                                           FontSize="11"
                                           Opacity="0.9"/>
                                    <Label Text="{Binding CallSingPlayer}"
                                           TextColor="White"
                                           FontSize="26"
                                           FontAttributes="Bold"/>
                                    <Label Text="{Binding PlayerName}"
                                           TextColor="#b3c96b"
                                           FontSize="14"
                                           Opacity="0.8"/>
                                </VerticalStackLayout>

                                <Border Grid.Column="2"
                                        BackgroundColor="#50b3c96b"
                                        Stroke="Transparent"
                                        StrokeShape="8"
                                        Padding="12,8">
                                    <Label Text="{Binding PlayerRole}"
                                           TextColor="White"
                                           FontSize="14"
                                           FontAttributes="Bold"/>
                                    
                                </Border>
                            </Grid>
                        </Border>

                        <BoxView HeightRequest="1" 
                                 Color="#b3c96b" 
                                 Opacity="0.2"/>

                        <!-- Статистика в сетке -->
                        <Grid Padding="15"
                              RowSpacing="12"
                              ColumnSpacing="12"
                              RowDefinitions="Auto, Auto"
                              ColumnDefinitions="*, *, *">

                            <!-- В ЗОНЕ -->
                            <Border Grid.Row="0"
                                   Grid.Column="0"
                                   BackgroundColor="#30808080"
                                   Stroke="#b3c96b"
                                   StrokeThickness="1"
                                   StrokeShape="10"
                                   Padding="12,8"
                                   Opacity="0.9">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="📅"
                                           FontSize="18"
                                           TextColor="#b3c96b"/>
                                    <Label Text="Дата регистрации"
                                           TextColor="#b3c96b"
                                           FontSize="10"
                                           Opacity="0.9"/>
                                    <Label Text="{Binding DataRegistr}"
                                           TextColor="White"
                                           FontSize="18"
                                           FontAttributes="Bold"/>                                   
                                </VerticalStackLayout>
                            </Border>

                            <!-- УБИЙСТВА -->
                            <Border Grid.Row="0"
                                   Grid.Column="1"
                                   BackgroundColor="#30808080"
                                   Stroke="#b3c96b"
                                   StrokeThickness="1"
                                   StrokeShape="10"
                                   Padding="12,8"
                                   Opacity="0.9">
                                <VerticalStackLayout Spacing="4">                                    
                                    <Label Text="⚔️"
                                           FontSize="18"
                                           TextColor="#b3c96b"/>                                    
                                    <Label Text="УБИЙСТВ"
                                           TextColor="#b3c96b"
                                           FontSize="10"
                                           Opacity="0.9"/>

                                        <Entry Text="{Binding CountKill}"
                                           TextColor="White"
                                                         IsEnabled="{Binding Path=UpdateMode}"
                                           FontSize="22"
                                           FontAttributes="Bold"/>
                                    <Label Text="_"
                                           TextColor="White"
                                           FontSize="9"
                                           Opacity="0.7"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- ТОЧНОСТЬ -->
                            <Border Grid.Row="0"
                                   Grid.Column="2"
                                   BackgroundColor="#30808080"
                                   Stroke="#b3c96b"
                                   StrokeThickness="1"
                                   StrokeShape="10"
                                   Padding="12,8"
                                   Opacity="0.9">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="🎯"
                                           FontSize="18"
                                           TextColor="#b3c96b"/>
                                    <Label Text="Смертей"
                                           TextColor="#b3c96b"
                                           FontSize="10"
                                           Opacity="0.9"/>
                                    <Entry Text="{Binding CountDieds}"
                                           TextColor="White"
                                                                 IsEnabled="{Binding UpdateMode}"
                                           FontSize="22"
                                           FontAttributes="Bold"/>
                                    <ProgressBar Progress="34"
                                                ProgressColor="#b3c96b"
                                                HeightRequest="4"
                                                WidthRequest="80"
                                                Opacity="0.8"/>
                                </VerticalStackLayout>
                            </Border>

                            <!-- ИГРЫ -->
                            <Border Grid.Row="1"
                                   Grid.Column="0"
                                   BackgroundColor="#30808080"
                                   Stroke="#b3c96b"
                                   StrokeThickness="1"
                                   StrokeShape="10"
                                   Padding="12,8"
                                   Opacity="0.9">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="🎮"
                                           FontSize="18"
                                           TextColor="#b3c96b"/>
                                    <Label Text="Командные игры"
                                           TextColor="#b3c96b"
                                           FontSize="10"
                                           Opacity="0.9"/>
                                    <Entry Text="{Binding CountFees}"
                                                            IsEnabled="{Binding UpdateMode}"
                                           TextColor="White"
                                           FontSize="20"
                                           FontAttributes="Bold"/>
                                   
                                </VerticalStackLayout>
                            </Border>

                            <!-- СБОРЫ -->
                            <Border Grid.Row="1"
                                   Grid.Column="1"
                                   BackgroundColor="#30808080"
                                   Stroke="#b3c96b"
                                   StrokeThickness="1"
                                   StrokeShape="10"
                                   Padding="12,8"
                                   Opacity="0.9">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="📋"
                                           FontSize="18"
                                           TextColor="#b3c96b"/>
                                    <Label Text="Мероприятия"
                                           TextColor="#b3c96b"
                                           FontSize="10"
                                           Opacity="0.9"/>
                                    <Entry Text="{Binding CountEvents}"
                                                               IsEnabled="{Binding UpdateMode}"
                                           TextColor="White"
                                           FontSize="20"
                                           FontAttributes="Bold"/>
                                    
                                </VerticalStackLayout>
                            </Border>

                            <!-- ЗАДАНИЯ -->
                            <Border Grid.Row="1"
                                   Grid.Column="2"
                                   BackgroundColor="#30808080"
                                   Stroke="#b3c96b"
                                   StrokeThickness="1"
                                   StrokeShape="10"
                                   Padding="12,8"
                                   Opacity="0.9">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="📌"
                                           FontSize="18"
                                           TextColor="#b3c96b"/>
                                    <Label Text="Достижений"
                                           TextColor="#b3c96b"
                                           FontSize="10"
                                           Opacity="0.9"/>
                                    <Label Text="{ Binding AchievementsCount}"
                                           TextColor="White"
                                           FontSize="20"
                                           FontAttributes="Bold"/>
                                    <Label Text="выполнено"
                                           TextColor="White"
                                           FontSize="9"
                                           Opacity="0.7"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- БЛОК 2: СНАРЯЖЕНИЕ -->
                <Border BackgroundColor="#50808080"
                        Stroke="#b3c96b"
                        StrokeThickness="1"
                        StrokeShape="15"
                        Padding="0"
                        Opacity="0.8">
                    <Border.Shadow>
                        <Shadow Brush="#b3c96b" 
                                Offset="0,0" 
                                Opacity="0.15"
                                Radius="15"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="0">
                        <Border BackgroundColor="#40808080"
                                Stroke="Transparent"
                                StrokeShape="0"
                                Padding="15,12">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="🎒"
                                       FontSize="20"
                                       TextColor="#b3c96b"/>
                                <Label Text="СНАРЯЖЕНИЕ"
                                       TextColor="White"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       VerticalTextAlignment="Center"/>
                                <Label Text="[02]"
                                       TextColor="#b3c96b"
                                       FontSize="12"
                                       Opacity="0.8"
                                       HorizontalOptions="Fill"
                                       VerticalTextAlignment="Center"/>
                            </HorizontalStackLayout>
                        </Border>

                        <BoxView HeightRequest="1" 
                                 Color="#b3c96b" 
                                 Opacity="0.3"/>

                        <!-- Оружие -->
                        <Grid Padding="15" ColumnSpacing="15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Основное -->
                            <Border
                                   Grid.Column="0"
                                   Grid.ColumnSpan="2"                                
                                   BackgroundColor="#30808080"
                                   Stroke="#b3c96b"
                                   StrokeThickness="1"
                                   StrokeShape="12"
                                   Padding="15">
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="🔫 Любимое оружие"
                                           TextColor="#b3c96b"
                                           FontSize="12"
                                           Opacity="0.9"/>
                                    <Label Text="{Binding LiveWeapon}"
                                           TextColor="White"
                                           FontSize="18"
                                           FontAttributes="Bold"/>
                                    <HorizontalStackLayout Spacing="12">
                                        <Label Text="⚡"
                                               FontSize="14"
                                               TextColor="#b3c96b"/>
                                        <Label Text="0.85"
                                               TextColor="White"
                                               FontSize="14"/>
                                        <Label Text="🎯"
                                               FontSize="14"
                                               TextColor="#b3c96b"/>
                                        <Label Text="50м"
                                               TextColor="White"
                                               FontSize="14"/>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Вторичное -->
                            
                        </Grid>

                        <BoxView HeightRequest="1" 
                                 Color="#b3c96b" 
                                 Margin="15,0"
                                 Opacity="0.2"/>
                    </VerticalStackLayout>
                </Border>

                <!-- БЛОК 3: ДОСТИЖЕНИЯ -->
                <Border BackgroundColor="#50808080"
                        Stroke="#b3c96b"
                        StrokeThickness="1"
                        StrokeShape="15"
                        Padding="0"
                        Opacity="0.8">
                    <Border.Shadow>
                        <Shadow Brush="#b3c96b" 
                                Offset="0,0" 
                                Opacity="0.15"
                                Radius="15"/>
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="0">
                        <Border BackgroundColor="#40808080"
                                Stroke="Transparent"
                                StrokeShape="0"
                                Padding="15,12">
                            <HorizontalStackLayout Spacing="10">
                                <Label Text="🏆"
                                       FontSize="20"
                                       TextColor="#b3c96b"/>
                                <Label Text="ДОСТИЖЕНИЯ"
                                       TextColor="White"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       VerticalTextAlignment="Center"/>
                                <Label Text="[03]"
                                       TextColor="#b3c96b"
                                       FontSize="12"
                                       Opacity="0.8"
                                       HorizontalOptions="Fill"
                                       VerticalTextAlignment="Center"/>
                                
                                <Button 
                                    Text="+" 
                                    Background="#90909060" 
                                    Command="{Binding AppendAchievementsCommand}"
                                    IsEnabled="{Binding UpdateMode}"/>
                                
                            </HorizontalStackLayout>
                        </Border>

                        <BoxView HeightRequest="1" 
                                 Color="#b3c96b" 
                                 Opacity="0.3"/>

                        <FlexLayout Direction="Row"
                                   Wrap="Wrap"
                                   Padding="15"
                                   JustifyContent="SpaceBetween">

                            <CollectionView
                                 x:Name="AchievementsList"
                                 BackgroundColor="#50508080"
                                ItemsSource="{Binding Achievements}" >
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border 
                                            BackgroundColor="#30808080"
                                            Stroke="#b3c96b"
                                            StrokeThickness="1"
                                            StrokeShape="12"
                                            Padding="15">
                                        
                                        <VerticalStackLayout Spacing="8">
                                            <Label Text="{Binding Path=NameAchievement}"
                                                   TextColor="#b3c96b"
                                                   FontSize="12"
                                                   Opacity="0.9"/>
                                            <Label Text="{Binding Path=Discription}"
                                                   TextColor="White"
                                                   FontSize="18"
                                                   FontAttributes="Bold"/>
                                        </VerticalStackLayout>
                                       </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </FlexLayout>
                    </VerticalStackLayout>
                </Border>
                <Border BackgroundColor="#40808080"
                        Stroke="#b3c96b"
                        StrokeThickness="1"
                        StrokeDashArray="4,2"
                        StrokeShape="0"
                        Padding="15"
                        Opacity="0.7">
                        <HorizontalStackLayout 
                                              Spacing="8"
                                              HorizontalOptions="Center"
                                              VerticalOptions="Center">
                        <Label Text="Проверено командиром   ✓"
                                   TextColor="#b3c96b"
                                   FontSize="17">
                            <Label.Triggers>
                                <DataTrigger
                                    TargetType="Label"
                                    Binding="{Binding CommanderIsCheck}"
                                    Value="false">
                                    <Setter Property="TextColor" Value="Red"/>
                                    <Setter Property="Text" Value="Командир не проводил проверку "/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        </HorizontalStackLayout>
                </Border>




                <Border
                      BackgroundColor="#50208080"
                      StrokeThickness="1"
                      StrokeShape="10"
                      Opacity="0.8">
                    <Button Text="Главная" Background="Transparent" Command="{Binding MoveMainPageCommand}"/>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </AbsoluteLayout>
</ContentPage>