<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="SquadApplication.ViewCustom.EventsForAllCommandsPage"
             BackgroundImageSource="events.jpg"
             Title="EventsForAllCommands">
    <RefreshView  >

            <!-- Шапка с фильтрами -->
        <CollectionView x:Name="EventsList"
                       BackgroundColor="#50508080"
                       ItemsSource="{Binding Path= Events}"
                       SelectionMode="Single"
                       >


            <CollectionView.Header>
                <VerticalStackLayout Spacing="10" Padding="10">

                    <!-- Панель поиска и фильтров -->
                    <Border BackgroundColor="#90201090"
                            Stroke="#2a3c5a"
                            StrokeThickness="1"
                            StrokeShape="10"
                            Padding="10">

                        <VerticalStackLayout Spacing="10">
                            <!-- Поиск -->
                            <Border BackgroundColor="#90303030"
                                    Stroke="#1e90ff"
                                    StrokeThickness="1"
                                    StrokeShape="8"
                                    Padding="10,5">
                                <Entry Placeholder="Поиск мероприятий..."
                                       TextColor="White"
                                       PlaceholderColor="#8da6c9"/>
                            </Border>

                            <!-- Фильтры в строку -->
                            <FlexLayout Direction="Row" 
                                       JustifyContent="SpaceBetween"
                                       Wrap="Wrap">

                                <Button Text="По дате"
                                        BackgroundColor="#1e90ff"
                                        TextColor="White"
                                        CornerRadius="8"
                                        Padding="15,8"/>

                                <Button Text="Прошедшие"
                                        BackgroundColor="#2a3c5a"
                                        TextColor="#8da6c9"
                                        CornerRadius="8"
                                        Padding="15,8"/>

                                <Button Text="Мои"
                                        BackgroundColor="#2a3c5a"
                                        TextColor="#8da6c9"
                                        CornerRadius="8"
                                        Padding="15,8"/>
                            </FlexLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Статистика -->
                    <Border BackgroundColor="#90201090"
                            Stroke="#1e90ff"
                            StrokeThickness="1"
                            StrokeShape="10"
                            Padding="15">

                        <FlexLayout Direction="Row" 
                                   JustifyContent="SpaceBetween">

                            <VerticalStackLayout Spacing="5">
                                <Label Text="12"
                                       TextColor="#00ff9d"
                                       FontSize="24"
                                       FontAttributes="Bold"/>
                                <Label Text="Всего"
                                       TextColor="#8da6c9"
                                       FontSize="12"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="3"
                                       TextColor="#1e90ff"
                                       FontSize="24"
                                       FontAttributes="Bold"/>
                                <Label Text="Предстоящих"
                                       TextColor="#8da6c9"
                                       FontSize="12"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="5">
                                <Label Text="2"
                                       TextColor="White"
                                       FontSize="24"
                                       FontAttributes="Bold"/>
                                <Label Text="Участвую"
                                       TextColor="#8da6c9"
                                       FontSize="12"/>
                            </VerticalStackLayout>
                        </FlexLayout>
                    </Border>

                    <!-- Кнопка создания (только для командира) -->
                    <Border x:Name="CreateEventButton"
                            BackgroundColor="#90407070"
                            Stroke="#00cc7a"
                            StrokeThickness="1"
                            StrokeShape="10"
                            Padding="10"
                            >

                        <HorizontalStackLayout Spacing="5"
                                              HorizontalOptions="Center">
                            <Button 
                                Opacity="0.7"
                                Text="Create event"
                                WidthRequest="360"
                                HeightRequest="50"
                                Background="#31113116"
                                FontFamily="24"
                                Command="{Binding CreateEventCommand}"/>

                        </HorizontalStackLayout>

                        
                    </Border>
                </VerticalStackLayout>
            </CollectionView.Header>

            <!-- Шаблон мероприятия -->
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="10,5"
                            Stroke="#2a3c5a"
                            StrokeThickness="1"
                            BackgroundColor="#1a2332"
                            StrokeShape="12"
                            Padding="0">

                        <!-- Индикатор статуса слева -->
                        <Grid ColumnDefinitions="5, *">

                            <!-- Цветная полоска статуса -->
                            <BoxView Grid.Column="0"
                                     Color="AliceBlue"
                                     Margin="0,10"/>

                            <!-- Контент мероприятия -->
                            <VerticalStackLayout Grid.Column="1"
                                               Spacing="8"
                                               Padding="15">

                                <!-- Заголовок и дата -->
                                <HorizontalStackLayout Spacing="10">
                                    <Label Text="{Binding NameGame}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalOptions="Center"/>

                                    <!-- Бейдж типа события -->
                                    <Border BackgroundColor="DarkGray"
                                            Stroke="Transparent"
                                            StrokeShape="6"
                                            Padding="8,3">
                                        <HorizontalStackLayout>
                                            
                                        <Label Text="Oрганизаторы :  "
                                               FontSize="10"
                                               TextColor="White"
                                               FontAttributes="Bold"/>
                                            <Label Text="{Binding TeamNameOrganization}"
                                               FontSize="10"
                                               TextColor="White"
                                               FontAttributes="Bold"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                    <Button Text="обновить"
                                            FontAttributes="Italic"
                                            HeightRequest="30"
                                            WidthRequest="50"
                                            FontSize="7"/>
                                </HorizontalStackLayout>

                                <!-- Дата и время -->
                                <HorizontalStackLayout Spacing="15">
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="📅"
                                               FontSize="14"
                                               TextColor="#8da6c9"/>
                                        <Label Text="{Binding Date}"
                                               FontSize="14"
                                               TextColor="#8da6c9"/>
                                    </HorizontalStackLayout>

                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="🕐"
                                               FontSize="14"
                                               TextColor="#8da6c9"/>
                                        <Label Text="{Binding Time}"
                                               FontSize="14"
                                               TextColor="#8da6c9"/>
                                    </HorizontalStackLayout>
                                </HorizontalStackLayout>

                                <!-- Полигон -->
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="📍"
                                           FontSize="14"
                                           TextColor="#8da6c9"/>
                                    <Label Text="{Binding CoordinatesPolygon}"
                                           FontSize="14"
                                           TextColor="#8da6c9"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout>
                                    <Label Text="📍"
                                       FontSize="17"
                                       TextColor="#8da6c9"
                                       MaxLines="2"
                                       LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding PolygonName}"
                                           FontSize="17"
                                           TextColor="#8da6c9"
                                           MaxLines="2"
                                           LineBreakMode="TailTruncation"
                                           />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="®  : "
                                           FontSize="16"
                                           TextColor="#8da6c9"/>
                                    <Editor Text="{Binding DescriptionShort}"
                                            FontSize="15"
                                            MaximumWidthRequest="300"
                                            AutoSize="TextChanges"
                                            IsEnabled="False"
                                            TextColor="#8da6c9"/>
                                           
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="10"
                                                        VerticalOptions="End">
                                    <HorizontalStackLayout Spacing="5">
                                        <Label Text="👥"
                                               FontSize="17"
                                               TextColor="#8da6c9"/>
                                        <Label Text="Участники "
                                               FontSize="17"
                                               TextColor="#8da6c9"/>
                                        <Label Text=": "
                                               FontSize="17"
                                               TextColor="#8da6c9"/>
                                        <Label Text="{Binding UsersCount}"
                                               FontSize="17"
                                               TextColor="#8da6c9"/>
                                    </HorizontalStackLayout>
                                </HorizontalStackLayout>
                                    <toolkit:Expander>
                                        <toolkit:Expander.Header>
                                        <Label Text="Полное описание ⇓ ⇓ ⇓"
                                               FontSize="17"
                                               
                                               TextColor="AliceBlue"/>
                                        </toolkit:Expander.Header>
                                        <StackLayout>
                                        <VerticalStackLayout>
                                            <HorizontalStackLayout Spacing="5">
                                                <Label Text="®  : "
                                                       FontSize="15"
                                                       TextColor="#8da6c9"/>
                                                <Editor Text="{Binding DescriptionFull}"
                                                        FontSize="15"
                                                        AutoSize="TextChanges"
                                                        MaximumWidthRequest="300"
                                                        MaximumHeightRequest="350"
                                                        TextColor="#8da6c9"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                            
                                        <HorizontalStackLayout>
                                        <Border BackgroundColor="Gray"
                                            Stroke="Transparent"
                                            StrokeShape="13"
                                            Padding="4,3">
                                                <Button Text="Отменить участие"
                                                        Command="{Binding BindingContext.UserIsNotGoRheGameCommand,Source={x:Reference EventsList}}"
                                                        CommandParameter="{Binding .}"
                                                        />
                                        </Border>
                                        <Border BackgroundColor="Gray"
                                                Stroke="Transparent"
                                                HorizontalOptions="Start"
                                                StrokeShape="13"
                                                Margin="80,0,0,0"
                                                Padding="4,3">
                                            <Button Text="Учавствую"
                                                    Command="{Binding BindingContext.UserIsGoRheGameCommand,Source={x:Reference EventsList}}"
                                                    CommandParameter="{Binding .}"
                                                    />
                                        </Border>
                                     </HorizontalStackLayout>
                                    </StackLayout>
                                    </toolkit:Expander>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <!-- Подвал -->
            <CollectionView.Footer>
                <Label Text="Конец списка"
                       TextColor="#8da6c9"
                       FontSize="12"
                       HorizontalOptions="Center"
                       Margin="0,20"/>
            </CollectionView.Footer>
        </CollectionView>
    </RefreshView>
</ContentPage>