<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SquadApplication.ViewCustom.CreateEventsForAllCommandsPage"
             BackgroundImageSource="updateprofileandequip.jpg"
             Title="NewPage1">    
    <ContentPage.Resources>
        <Style TargetType="Border" x:Key="BorderStylesCust">
            <Setter Property="Margin" Value="12"/>
            <Setter Property="BackgroundColor" Value="#40808080"/>
            <Setter Property="Stroke" Value="#b3c96b"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="StrokeDashArray" Value="1,2"/>
            <Setter Property="StrokeShape" Value="11"/>
        </Style>
    </ContentPage.Resources>
    
        <Border
            Stroke="#2a3c5a"
            BackgroundColor="#98398080"
            StrokeThickness="3"
            StrokeDashArray="2,2"
            StrokeShape="13"
            Padding="5">
    <VerticalStackLayout
        Margin="5">
        
            <Border 
                     Stroke="DarkCyan"
                     Margin="5"                
                     StrokeThickness="1"
                     StrokeShape="10"
                     BackgroundColor="#98399989" >
                <Label
                     Text="{Binding TeamNameOrganization}"
                     TextColor="White"
                     FontSize="20"
                     BackgroundColor="Transparent"/>
            </Border>
        
        
            <Border 
                    Margin="5"
                    Stroke="DarkCyan"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    BackgroundColor="#98399989">
                <Entry
                     Placeholder="Укажите название игры"
                     PlaceholderColor="LightGray"
                     Text="{Binding NameGame}"
                     TextColor="White"
                     FontSize="20"
                     BackgroundColor="Transparent"/>
            </Border>
            <Border 
                 Margin="5"
                 Stroke="DarkCyan"
                 StrokeThickness="1"
                 StrokeShape="RoundRectangle 10"
                 BackgroundColor="#98399989">
            <Editor
                 Placeholder="Краткое содержание об игре"
                 PlaceholderColor="LightGray"
                 Text="{Binding DescriptionShort}"
                 TextColor="White"
                 FontSize="20"
                 BackgroundColor="#98399989"/>
            </Border>
            <Border 
                Margin="5"
                Stroke="DarkCyan"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 10"
                BackgroundColor="#98399989">
            <Editor
                Placeholder="Полное описание игры "
                PlaceholderColor="LightGray"
                Text="{Binding DescriptionFull}"
                TextColor="White"
                FontSize="20"
                BackgroundColor="Transparent"/>
            </Border>
            <Border 
                  Margin="5"
                  Stroke="DarkCyan"
                  StrokeThickness="1"
                  StrokeShape="RoundRectangle 10"
                  BackgroundColor="#98399989">
            <Entry
                  Placeholder="Координаты полигона"
                  PlaceholderColor="LightGray"
                  Text="{Binding CoordinatesPolygon}"
                  TextColor="White"
                  FontSize="20"
                  BackgroundColor="Transparent"/>
            </Border>
            <Border 
                  Margin="5"
                  Stroke="DarkCyan"
                  StrokeThickness="1"
                  StrokeShape="RoundRectangle 10"
                  BackgroundColor="#98399989">
                <Entry
                     Placeholder="Дата (12.30.2026)"
                     PlaceholderColor="LightGray"
                     Text="{Binding Dategame}"
                     TextColor="White"
                     FontSize="20"
                     BackgroundColor="Transparent"/>
            </Border>
            <Border 
                  Margin="5"
                  Stroke="DarkCyan"
                  StrokeThickness="1"
                  StrokeShape="RoundRectangle 10"
                  BackgroundColor="#98399989">
                <Entry
                   Placeholder="Время (09:30)"
                   PlaceholderColor="LightGray"
                   Text="{Binding TimeGame}"
                   TextColor="White"
                   FontSize="20"
                   BackgroundColor="Transparent"/>
            </Border>
            <Border 
       Margin="5"
       Stroke="DarkCyan"
       StrokeThickness="1"
       StrokeShape="RoundRectangle 10"
       BackgroundColor="#98399989">
                <Entry
          Placeholder="Название полигона (опционально)"
          PlaceholderColor="LightGray"
          Text="{Binding PolygonName}"
          TextColor="White"
          FontSize="20"
          BackgroundColor="Transparent"/>
            </Border>
            <Border
                    Style="{StaticResource Key=BorderStylesCust}">
                <Border.Shadow>
                    <Shadow Brush="LightGray" 
                            Offset="0,5" 
                            Opacity="1.0"
                            Radius="20"/>
                </Border.Shadow>
                <Button
                    BackgroundColor="#40808080"
                    Text="Create"
                    Command="{Binding RequestFolCreateEventCommand}"
                    FontSize="20"/>
            </Border>
        
        
            <Border
                  Style="{StaticResource Key=BorderStylesCust}" >
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsUpdateThisGame}" Value="false">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="IsEnabled" Value="false"/>
                    </DataTrigger>
                </Border.Triggers>
                <Border.Shadow>
                    <Shadow Brush="LightGray" 
                 Offset="0,5" 
                 Opacity="1.0"
                 Radius="20"/>
                </Border.Shadow>
                <Button
         BackgroundColor="#40808080"
         Text="Update"
         Command="{Binding RequestFolUpdateEventCommand}"
         FontSize="20"/>
            </Border>
        
        
            <Border
                 Style="{StaticResource Key=BorderStylesCust}">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsUpdateThisGame}" Value="false">
                        <Setter Property="Opacity" Value="0"/>
                        <Setter Property="IsEnabled" Value="False"/>
                    </DataTrigger>
                </Border.Triggers>
                <Border.Shadow>
                    <Shadow Brush="LightGray" 
                 Offset="0,5" 
                 Opacity="1.0"
                 Radius="20"/>
                </Border.Shadow>
                <Button
         BackgroundColor="#40808080"
         Text="Delete"
         Command="{Binding DeleteEventCommand}"
         FontSize="20"/>
            </Border>

        </VerticalStackLayout>

        </Border>
</ContentPage>