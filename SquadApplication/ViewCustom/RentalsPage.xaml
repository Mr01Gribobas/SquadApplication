<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SquadApplication.ViewCustom.RentalsPage"
             BackgroundImageSource="rentails.jpg"
             Title="RentalsPage">
    <VerticalStackLayout
        x:Name="loyoutItem"
        BackgroundColor="#50508080"
        >
        
        <ScrollView>
            <StackLayout >
                <Button 
                    Margin="5"
                BackgroundColor="DarkGreen"
                Command="{Binding CreateRentalCommand}"
                Text="Add Rentail">
                    <Button.Triggers>
                        <DataTrigger
                  TargetType="Button"
                  Binding="{Binding RoleUser}"
                  Value="Private"
                             >
                            <Setter Property="IsEnabled" Value="False"/>
                        </DataTrigger>
                    </Button.Triggers>
                </Button>
                <CollectionView x:Name="RentalListViewItem"  
                                Background="Transparent"
                                ItemsSource="{Binding Rentals}"
                                VerticalOptions="Fill"
                                HorizontalOptions="Fill"
                                >
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                  BackgroundColor="#90909080"
                                  Stroke="#b3c96b"
                                  StrokeThickness="2"
                                  StrokeDashArray="4,2"
                                  StrokeShape="0"
                                  Padding="10"
                                  Opacity="0.8">
                                <VerticalStackLayout>
                                    
                                <Grid ColumnDefinitions="auto,auto">
                                        <VerticalStackLayout Grid.Column="1">
                                            <HorizontalStackLayout>
                                                <Label Text="Внутренняя защита  : " TextColor="White" FontSize="15"/>
                                                <Label Text="{Binding _sVMP}" TextColor="White" FontSize="15"/>
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout>
                                                <Label Text="Верхняя одежда : " TextColor="White" FontSize="15"/>
                                                <Label Text="{Binding _outterwear}" TextColor="White" FontSize="15"/>
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout>
                                                <Label Text="Плитник\Разгруз : " TextColor="White" FontSize="15"/>
                                                <Label Text="{Binding _bulletproofVestOrUnloadingVest}" TextColor="White" FontSize="15"/>
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout>
                                                <Label Text="Перчатки защитные : " TextColor="White" FontSize="15"/>
                                                <Label Text="{Binding _gloves}" TextColor="White" FontSize="15"/>
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout>
                                                <Label Text="Статус проката : " TextColor="White" FontSize="15"/>
                                                <Label Text="{Binding _isStaffed}" TextColor="White" FontSize="14"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="0">
                                        <HorizontalStackLayout>
                                            <Label Text="Номер проката : " TextColor="White" FontSize="15"/>
                                            <Label Text="{Binding _numderRental}" TextColor="White" FontSize="15"/>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout>
                                            <Label Text="Оружие : " TextColor="White" FontSize="15"/>
                                            <Label Text="{Binding _weapon}" TextColor="White" FontSize="15"/>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout>
                                            <Label Text="Защиткая маска : " TextColor="White" FontSize="15"/>
                                            <Label Text="{Binding _mask}" TextColor="White" FontSize="15"/>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout>
                                            <Label Text="Шлем : " TextColor="White" FontSize="15"/>
                                            <Label Text="{Binding _helmet}" TextColor="White" FontSize="15"/>
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout>
                                            <Label Text="Балаклава : " TextColor="White" FontSize="15"/>
                                            <Label Text="{Binding _balaclava}" TextColor="White" FontSize="15"/>
                                        </HorizontalStackLayout>
                                        
                                    </VerticalStackLayout>

                                </Grid>
                                    <Border 
                                            Stroke="GreenYellow"
                                            StrokeThickness="1"
                                            Padding="2"
                                           HorizontalOptions="Center"
                                          >
                                        <Button 
                                              Text="Обновить"
                                              BackgroundColor="#90509010"
                                              Command="{Binding BindingContext.UpdateRentalCommand, Source={x:Reference RentalListViewItem}}"  
                                              CommandParameter="{Binding .}" />
                                    </Border>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </StackLayout>
        </ScrollView>


    </VerticalStackLayout>
</ContentPage>